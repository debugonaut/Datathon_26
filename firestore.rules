rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // Default rule for everything else (for demo purposes)
      allow read, write: if request.auth != null;
    }

    match /complaints/{complaintId} {
      allow read: if request.auth != null
        && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'warden'
          || request.auth.uid == resource.data.studentUid
        );
      // Client-side code strips internalNotes before hitting this rule for students, 
      // but in a production environment, field-level rules or Cloud Functions should enforce it.
      allow write: if request.auth != null;
    }
  }
}
